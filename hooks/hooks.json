{
  "description": "AFK supervisor lifecycle reconciliation",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/supervisor/hook-handler.mjs\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/supervisor/hook-handler.mjs\""
          }
        ]
      }
    ]
  }
}
